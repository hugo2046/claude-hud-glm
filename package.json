{
  "name": "claude-hud-glm",
  "version": "0.4.2-glm.1",
  "description": "Real-time statusline HUD for Claude Code (GLM fork with Zhipu quota)",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "commands/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 npm test",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"Opus\"},\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"transcript_path\":\"/tmp/test.jsonl\"}' | node dist/index.js"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "hud"
  ],
  "author": "Jarrod Watts",
  "license": "MIT",
  "homepage": "https://github.com/hugo2046/claude-hud-glm",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugo2046/claude-hud-glm.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "typescript": "^7.0.2"
  }
}
